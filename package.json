{
  "name": "skipcourse-tracker",
  "displayName": "skipcourse-tracker",
  "description": "Streamline syncing your local coding projects directly to SkipCourse.",
  "publisher": "openlyfree",
  "version": "0.0.2",
  "repository": {
    "type": "git",
    "url": "https://github.com/openlyfree/skipcourse-tracker.git"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "skipcourse-tracker.manualUpload",
        "title": "SkipCourse Upload"
      },
      {
        "command": "skipcourse-tracker.resetProfile",
        "title": "Reset SkipCourse Profile"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "SkipCourse Tracker",
      "properties": {
        "skipcourse-tracker.browserPath": {
          "type": "string",
          "default": "",
          "description": "Optional path to a browser executable (Chrome/Chromium/Edge/Brave). Leave empty to use Playwright bundled browser."
        },
        "skipcourse-tracker.profilePath": {
          "type": "string",
          "default": "",
          "description": "Optional absolute path for storing the persistent Playwright profile. Leave empty to use the default (HOME/.skipcourse-tracker-profile)."
        },
        "skipcourse-tracker.headed": {
          "type": "boolean",
          "default": false,
          "description": "Launch browser in headed mode for troubleshooting (overrides headless mode during uploads if true)."
        }
      }
    }
  },

  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "format": "prettier --write *"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "24.x",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  },
  "dependencies": {
    "playwright": "^1.61.1"
  }
}
